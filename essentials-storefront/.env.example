# GAG Originals Storefront — Environment Variables
# Copy this file to .env.local and fill in the values.

# Medusa backend URL (default: http://localhost:9001)
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9001

# Medusa publishable API key (get from Admin → Settings → API Keys)
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

# Medusa sales channel ID (get from Admin → Settings → Sales Channels)
NEXT_PUBLIC_STORE_SALES_CHANNEL_ID=
